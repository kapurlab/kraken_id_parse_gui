#!/usr/bin/env bash
# Kraken ID Parse GUI OOD batch_connect script.
# $port (uvicorn) is exported by before.sh.

echo "=== Kraken ID Parse GUI Session Starting ==="
echo "uvicorn:${port}"

# Shared conda env installed at the tool root.
# Falls back to a personal install if the shared env is absent.
SHARED_ENV=/srv/kapurlab/tools/kraken_id_parse_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/kraken_id_parse
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  KRAKEN_ENV="${SHARED_ENV}"
  PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  KRAKEN_ENV="${PERSONAL_ENV}"
  PYTHON="${PERSONAL_ENV}/bin/python"
else
  KRAKEN_ENV=""
  PYTHON="${PERSONAL_BASE_PYTHON}"
fi

# Tool source (shared install only — no per-user fallback for the app itself)
KRAKEN_GUI=/srv/kapurlab/tools/kraken_id_parse_gui

# Add the conda env bin and the kraken bin/ scripts to PATH
export PATH="${KRAKEN_ENV}/bin:${PATH}"
# PYTHONPATH lets the kraken CLI scripts find each other (local imports in bin/)
export PYTHONPATH="${KRAKEN_GUI}/bin:${PYTHONPATH}"

cd "${KRAKEN_GUI}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env:  ${KRAKEN_ENV}"
echo "  kraken_gui: ${KRAKEN_GUI}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info
