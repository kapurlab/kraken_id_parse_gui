#!/usr/bin/env bash
# Kraken ID Parse GUI (dev) OOD batch_connect script.
# $port (uvicorn) and $worktree_dir are exported by before.sh.erb.

echo "=== Kraken ID Parse GUI (dev) Session Starting ==="
echo "uvicorn:${port}"
echo "worktree:${worktree_dir}"

SHARED_ENV=/srv/kapurlab/tools/kraken_id_parse_gui/env
PERSONAL_ENV=/home/${USER}/miniforge3/envs/kraken_id_parse
PERSONAL_BASE_PYTHON=/home/${USER}/miniforge3/bin/python

if [ -d "${SHARED_ENV}" ] && [ -x "${SHARED_ENV}/bin/python" ]; then
  KRAKEN_ENV="${SHARED_ENV}"
  PYTHON="${SHARED_ENV}/bin/python"
elif [ -d "${PERSONAL_ENV}" ]; then
  KRAKEN_ENV="${PERSONAL_ENV}"
  PYTHON="${PERSONAL_ENV}/bin/python"
else
  KRAKEN_ENV=""
  PYTHON="${PERSONAL_BASE_PYTHON}"
fi

# Dev override: prefer the per-session worktree if before.sh.erb set one.
SHARED_KRAKEN_GUI=/srv/kapurlab/tools/kraken_id_parse_gui
if [ -n "${worktree_dir}" ] && [ -d "${worktree_dir}/backend" ]; then
  KRAKEN_DIR="${worktree_dir}"
else
  KRAKEN_DIR="${SHARED_KRAKEN_GUI}"
fi

export PATH="${KRAKEN_ENV}/bin:${PATH}"
export PYTHONPATH="${KRAKEN_DIR}/bin:${PYTHONPATH}"

cd "${KRAKEN_DIR}/backend"
echo "Starting uvicorn on port ${port}"
echo "  conda env:  ${KRAKEN_ENV}"
echo "  kraken_gui: ${KRAKEN_DIR}"
exec $PYTHON -m uvicorn app.main:app \
    --host 0.0.0.0 \
    --port "${port}" \
    --log-level info \
    --reload \
    --reload-dir app
